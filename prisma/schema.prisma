// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AccType {
  PAID
  FREE
}

enum PaymentProvider {
  SUMUP
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}
enum UserType {
  CLIENT
  INFULENCER
}

model User {
  id            String    @id @default(nanoid())
  srn           Int       @unique @default(autoincrement())
  name          String
  tradingViewId String?   @unique
  mobile        String    @unique
  email         String    @unique
  planType      AccType?
  version       String?   @default("Latest")
  userType      UserType  @default(CLIENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  discount      Int?
  payments      Payment[] @relation("PaymentClient")
  referrals     Payment[] @relation("PaymentPromoter")

  @@index([email])
  @@index([mobile])
  @@index([tradingViewId])
}

model Payment {
  id                String        @id @default(cuid())
  status            PaymentStatus @default(PENDING)
  amount            Decimal       @db.Decimal(10, 2)
  currency          String
  checkoutId        String?       @unique
  checkoutReference String        @unique
  merchantCode      String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  userId            String?
  user              User?         @relation("PaymentClient", fields: [userId], references: [id])

  promoterId        String?
  promoter          User?         @relation("PaymentPromoter", fields: [promoterId], references: [id])

  @@index([userId])
  @@index([promoterId])
}